DJANGO_SECRET_KEY=replace-with-a-secure-secret-key
DEBUG=False
ALLOWED_HOSTS=127.0.0.1,localhost,.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-project.vercel.app

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Vercel Postgres may provide POSTGRES_URL instead. The app reads DATABASE_URL first, then POSTGRES_URL, then POSTGRES_URL_NON_POOLING.
# POSTGRES_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=portfolio@example.com
